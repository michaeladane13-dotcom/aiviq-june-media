# Simple password gate for the dashboard (checked via middleware)
DASHBOARD_PASSWORD=

# Google OAuth (refresh-token flow — see brief Step 1-4)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Comma-separated extra shift days for Wed-Sat, e.g. "THU,SAT"
# Valid values: WED,THU,FRI,SAT  (Sun/Mon/Tue are always night shifts)
EXTRA_SHIFT_DAYS=THU
